# Client-side Pollinations API key (VITE_ prefix exposes it to the browser)
VITE_POLLINATIONS_API_KEY=
VITE_OPENAI_BASE_URL=https://gen.pollinations.ai/v1

# Server-side secret key for Netlify proxy (never exposed to browser)
POLLINATIONS_API=

# Route through Netlify serverless proxy to keep sk_ keys off the client
USE_SERVER_PROXY=false
